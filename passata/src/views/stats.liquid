{% layout "layout.liquid" %}
{% block content %}
<div x-data="statsApp()" x-init="init()">
  <section class="section">
    <h2 class="title">Total Pomodoros: <span x-text="stats.total"></span></h2>
    
    <div class="stats-grid">
      <div class="card">
        <div class="card-content">
          <h3 class="subtitle">By Day</h3>
          <template x-for="(count, date) in stats.byDay" :key="date">
            <div class="stat-row">
              <span x-text="date"></span>
              <span x-text="count"></span>
            </div>
          </template>
        </div>
      </div>

      <div class="card">
        <div class="card-content">
          <h3 class="subtitle">By Tag</h3>
          <template x-for="(count, tag) in stats.byTag" :key="tag">
            <div class="stat-row">
              <span class="tag" x-text="tag"></span>
              <span x-text="count"></span>
            </div>
          </template>
        </div>
      </div>
    </div>
  </section>
</div>
{% endblock %}
